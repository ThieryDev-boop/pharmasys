Options -Indexes
RewriteEngine On

# Bloquer l'acces aux dossiers sensibles
RewriteRule ^(config|app|lib|storage|scripts)/ - [F,L]

# Toutes les requetes vers index.php (sauf fichiers existants)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
